{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessforge.dev/schemas/effectiveness-evidence.v1",
  "title": "HarnessForge effectiveness evidence report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "claim",
    "target",
    "candidate",
    "baseline",
    "evaluation",
    "metrics",
    "safety",
    "cost",
    "evidence",
    "promotion"
  ],
  "properties": {
    "schemaVersion": {
      "const": "harnessforge.effectivenessEvidence.v1"
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "summary",
        "scope",
        "verdict"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "scope": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "verdict": {
          "enum": [
            "candidate_better",
            "candidate_not_better",
            "inconclusive",
            "blocked"
          ]
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "root"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "root": {
          "type": [
            "string",
            "null"
          ],
          "description": "Redacted or omitted local root path. Null is preferred for portable artifacts."
        }
      }
    },
    "candidate": {
      "$ref": "#/$defs/harnessSnapshot"
    },
    "baseline": {
      "$ref": "#/$defs/harnessSnapshot"
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "replayType",
        "feedbackChannels",
        "taskSet",
        "runtimeBudget",
        "workspaceContract",
        "adapterContract",
        "reproductionCommand"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "replayType": {
          "$ref": "#/$defs/replayType"
        },
        "feedbackChannels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/feedbackChannel"
          },
          "uniqueItems": true
        },
        "taskSet": {
          "$ref": "#/$defs/taskSet"
        },
        "runtimeBudget": {
          "$ref": "#/$defs/runtimeBudget"
        },
        "workspaceContract": {
          "$ref": "#/$defs/workspaceContract"
        },
        "adapterContract": {
          "$ref": "#/$defs/adapterContract"
        },
        "reproductionCommand": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "worstCase",
        "doNoHarmFloor",
        "secondary"
      ],
      "properties": {
        "primary": {
          "$ref": "#/$defs/metric"
        },
        "worstCase": {
          "$ref": "#/$defs/metric"
        },
        "doNoHarmFloor": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "metric",
            "minimum",
            "met"
          ],
          "properties": {
            "metric": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "minimum": {
              "type": "number"
            },
            "met": {
              "type": "boolean"
            }
          }
        },
        "secondary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric"
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trajectoryReviewed",
        "permissionBoundaryReviewed",
        "violations"
      ],
      "properties": {
        "trajectoryReviewed": {
          "type": "boolean"
        },
        "permissionBoundaryReviewed": {
          "type": "boolean"
        },
        "violations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "optimized",
        "dimensions"
      ],
      "properties": {
        "optimized": {
          "type": "boolean"
        },
        "dimensions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/costDimension"
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resultArtifacts",
        "reviewedBy",
        "reviewedAt",
        "notes"
      ],
      "properties": {
        "resultArtifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          }
        },
        "reviewedBy": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "reviewedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "humanApproved",
        "rollback"
      ],
      "properties": {
        "status": {
          "enum": [
            "proposal",
            "promoted",
            "rejected",
            "deferred"
          ]
        },
        "humanApproved": {
          "type": "boolean"
        },
        "rollback": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "repoRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(^|/)\\.\\.($|/)).+"
    },
    "replayType": {
      "enum": [
        "live",
        "counterfactual_replay",
        "frozen_replay"
      ]
    },
    "harnessSurface": {
      "enum": [
        "reasoning",
        "action",
        "environment",
        "mechanism",
        "scaling",
        "domain"
      ]
    },
    "feedbackChannel": {
      "enum": [
        "compile",
        "test",
        "runtime_error",
        "static_analysis",
        "security",
        "fuzzing",
        "simulation",
        "profiling",
        "cost",
        "human_review",
        "trajectory",
        "permission_boundary"
      ]
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshotId",
        "artifactRefs"
      ],
      "properties": {
        "snapshotId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "artifactRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/repoRelativePath"
          }
        }
      }
    },
    "harnessSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "changedSurfaces",
        "snapshot"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "changedSurfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/harnessSurface"
          },
          "uniqueItems": true
        },
        "snapshot": {
          "$ref": "#/$defs/snapshot"
        }
      }
    },
    "taskSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "sampleCount",
        "heldOut",
        "contaminationControls"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "sampleCount": {
          "type": "integer",
          "minimum": 1
        },
        "heldOut": {
          "type": "boolean"
        },
        "contaminationControls": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "runtimeBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wallClockSeconds",
        "modelCalls",
        "tokens",
        "toolCalls",
        "retries"
      ],
      "properties": {
        "wallClockSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "modelCalls": {
          "type": "integer",
          "minimum": 0
        },
        "tokens": {
          "type": "integer",
          "minimum": 0
        },
        "toolCalls": {
          "type": "integer",
          "minimum": 0
        },
        "retries": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "workspaceContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "dependencies",
        "networkAccess",
        "cleanup",
        "scoringEntrypoint"
      ],
      "properties": {
        "state": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "dependencies": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "networkAccess": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "cleanup": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "scoringEntrypoint": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "adapterContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "normalization",
        "agents",
        "modelPolicy"
      ],
      "properties": {
        "normalization": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "agents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "modelPolicy": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "candidateSensitive",
        "direction",
        "baselineValue",
        "candidateValue",
        "unit"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "candidateSensitive": {
          "type": "boolean"
        },
        "direction": {
          "enum": [
            "higher_is_better",
            "lower_is_better"
          ]
        },
        "baselineValue": {
          "type": [
            "number",
            "null"
          ]
        },
        "candidateValue": {
          "type": [
            "number",
            "null"
          ]
        },
        "unit": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "costDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "unit",
        "baselineValue",
        "candidateValue"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "unit": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "baselineValue": {
          "type": [
            "number",
            "null"
          ]
        },
        "candidateValue": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind",
        "redacted"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/repoRelativePath"
        },
        "kind": {
          "enum": [
            "result-log",
            "trace",
            "scorecard",
            "candidate-snapshot",
            "review-note"
          ]
        },
        "redacted": {
          "type": "boolean"
        }
      }
    }
  }
}
