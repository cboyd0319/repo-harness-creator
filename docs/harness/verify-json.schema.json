{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessforge.dev/schemas/verify-json.v1",
  "title": "HarnessForge verify --json report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "target",
    "mode",
    "verdict",
    "platform",
    "execution",
    "summary",
    "checks",
    "blockedReasons",
    "warnings",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": {
      "const": "harnessforge.verify.v1"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "root"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "root": {
          "type": [
            "string",
            "null"
          ],
          "description": "Redacted or omitted local root path. Null is preferred for portable artifacts."
        }
      }
    },
    "mode": {
      "enum": [
        "plan",
        "run"
      ]
    },
    "verdict": {
      "enum": [
        "planned",
        "warning",
        "blocked",
        "passed",
        "failed"
      ]
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os",
        "python",
        "runner"
      ],
      "properties": {
        "os": {
          "type": "string"
        },
        "python": {
          "type": "string"
        },
        "runner": {
          "type": "string"
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commandsExecuted",
        "startedAt",
        "endedAt",
        "durationMs"
      ],
      "properties": {
        "commandsExecuted": {
          "type": "boolean"
        },
        "startedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "endedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "durationMs": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "planned",
        "skipped",
        "blocked",
        "passed",
        "failed",
        "timedOut",
        "errors"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "planned": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "timedOut": {
          "type": "integer",
          "minimum": 0
        },
        "errors": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "blockedReasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    }
  },
  "$defs": {
    "checkStatus": {
      "enum": [
        "planned",
        "skipped",
        "blocked",
        "passed",
        "failed",
        "timed_out",
        "error"
      ]
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "command",
        "source",
        "workingDirectory",
        "required",
        "status",
        "exitCode",
        "durationMs",
        "message",
        "stdoutPreview",
        "stderrPreview"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "enum": [
            "detected",
            "explicit",
            "manifest",
            "generated"
          ]
        },
        "workingDirectory": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "status": {
          "$ref": "#/$defs/checkStatus"
        },
        "exitCode": {
          "type": [
            "integer",
            "null"
          ]
        },
        "durationMs": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "message": {
          "type": "string"
        },
        "stdoutPreview": {
          "type": [
            "string",
            "null"
          ]
        },
        "stderrPreview": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        }
      }
    }
  }
}
