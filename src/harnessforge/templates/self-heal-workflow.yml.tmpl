name: Harness Self Heal

on:
  workflow_dispatch:

permissions:
  contents: write
  pull-requests: write

concurrency:
  group: harness-self-heal
  cancel-in-progress: false

jobs:
  refresh:
    name: Refresh harness and open review PR
    runs-on: ubuntu-22.04
    timeout-minutes: 20
    steps:
      - name: Checkout
        uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10 # v6
        with:
          fetch-depth: 0

      - name: Apply safe harness updates
        uses: cboyd0319/harnessforge@<reviewed-commit-sha> # v1
        with:
          command: update
          apply: "true"
          with-ci-workflow: "false"
          with-self-heal-workflow: "true"

      - name: Verify
        run: |
          set -euo pipefail
          ./init.sh
          git diff --check

      - name: Create pull request
        env:
          GH_TOKEN: ${{ github.token }}
        run: |
          set -euo pipefail
          if [ -z "$(git status --porcelain)" ]; then
            echo "No harness changes detected."
            exit 0
          fi

          branch="harness/self-heal-${GITHUB_RUN_ID}"
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git switch -c "$branch"
          git add AGENTS.md feature_list.json progress.md session-handoff.md init.sh init.ps1 scripts/check_pins.py docs/harness .github/workflows/harness-self-heal.yml
          git commit -m "docs(harness): refresh generated harness"
          git push --set-upstream origin "$branch"
          gh pr create \
            --title "Refresh generated repo harness" \
            --body "Manual self-heal scaffold run. Review generated harness changes before merging." \
            --base main \
            --head "$branch"
