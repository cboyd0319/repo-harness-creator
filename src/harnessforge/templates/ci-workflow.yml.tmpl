name: HarnessForge

on:
  workflow_dispatch:

permissions:
  contents: read

concurrency:
  group: harnessforge-${{ github.workflow }}-${{ github.event.pull_request.number || github.ref }}
  cancel-in-progress: true

jobs:
  harness:
    name: Repo harness checks
    runs-on: ubuntu-22.04
    steps:
      - uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10 # v6
        with:
          persist-credentials: false

      # REVIEW REQUIRED: verify evidence gating is off by default.
      # Set require-verify-evidence to "true" only after this repo stores
      # reviewed run-mode docs/harness/evidence/verify*.json reports and
      # wants release promotion to block without current passing evidence.
      - name: Read-only sync preflight
        id: sync
        continue-on-error: true
        uses: cboyd0319/harnessforge@<reviewed-commit-sha> # v1
        with:
          command: sync
          require-verify-evidence: "false"
          json-report: docs/harness/evidence/sync-preflight.json

      - name: Stop on blocked readiness
        if: ${{ steps.sync.outputs['sync-exit-code'] == '2' }}
        shell: bash
        run: |
          echo "HarnessForge sync preflight is blocked."
          echo "Review docs/harness/evidence/sync-preflight.json and the sync summary."
          exit 2

      - name: Repo harness audit
        uses: cboyd0319/harnessforge@<reviewed-commit-sha> # v1
        with:
          command: audit
          min-score: "85"
          html-report: harness-report.html
          json-report: harness-report.json
